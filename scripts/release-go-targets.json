{
  "schema": "flowersec.release-go-targets.v1",
  "platforms": {
    "archive": [
      { "goos": "linux", "goarch": "amd64" },
      { "goos": "linux", "goarch": "arm64" }
    ],
    "image": [
      { "goos": "linux", "goarch": "amd64" },
      { "goos": "linux", "goarch": "arm64" }
    ]
  },
  "distributions": {
    "runtime": {
      "platforms": "archive",
      "targets": [
        { "module": "flowersec-go", "package": "./cmd/flowersec-runtime" }
      ]
    },
    "runtime-image": {
      "platforms": "image",
      "targets": [
        { "module": "flowersec-go", "package": "./cmd/flowersec-runtime" }
      ]
    }
  }
}
