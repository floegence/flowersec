{
  "name": "@floegence/flowersec-core",
  "version": "2.0.0",
  "description": "Flowersec core TypeScript library for carrier-neutral encrypted sessions and multiplexed streams.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/floegence/flowersec.git"
  },
  "bugs": {
    "url": "https://github.com/floegence/flowersec/issues"
  },
  "homepage": "https://github.com/floegence/flowersec#readme",
  "type": "module",
  "main": "./dist/facade.js",
  "types": "./dist/facade.d.ts",
  "files": [
    "dist/**",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md",
    "sbom/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/facade.d.ts",
      "default": "./dist/facade.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "default": "./dist/browser/index.js"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "overrides": {
    "brace-expansion@^1.1.7": "^1.1.16",
    "brace-expansion@^2.0.1": "^2.1.2",
    "js-yaml": "^4.3.0",
    "postcss": "^8.5.23"
  },
  "scripts": {
    "build": "node ./scripts/clean-dist.mjs && tsc -p tsconfig.build.json && node ./scripts/build-browser-vendor.mjs && node ./scripts/prune-dist.mjs",
    "bench": "vitest bench --run",
    "test": "npm run build && vitest run",
    "test:browser": "npm run build && playwright test",
    "test:browser:chromium": "npm run build && playwright test --project=chromium",
    "test:browser:webkit": "npm run build && playwright test --project=webkit-smoke",
    "ensure:browser": "node ./scripts/ensure-playwright-browsers.mjs",
    "test:coverage": "npm run build && vitest run --coverage",
    "lint": "eslint .",
    "verify:package": "node ./scripts/verify-package-exports.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm run verify:package"
  },
  "dependencies": {
    "@noble/ciphers": "^0.6.0",
    "@noble/curves": "^1.9.0",
    "@noble/hashes": "^1.8.0",
    "tr46": "5.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/node": "^24.0.0",
    "@types/ws": "^8.5.12",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "4.1.0",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "ajv-formats-draft2019": "1.6.1",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "4.1.0"
  }
}
