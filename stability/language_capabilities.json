      }
    },
    {
      "id": "rpc",
      "description": "Bounded RPC clients, servers, calls, notifications, cancellation, and timeouts",
      "implementations": {
        "go": { "status": "complete", "evidence": ["flowersec-go/rpc"] },
        "typescript": { "status": "complete", "evidence": ["flowersec-ts/src/rpc"] },
