{
  "version": 1,
  "languages": ["go", "typescript", "swift", "rust"],
  "portable_capabilities": [
    {
      "id": "wire_idl",
      "description": "Core wire types, strict validation, and typed RPC generation",
      "implementations": {
        "go": { "status": "complete", "evidence": ["tools/idlgen/main.go", "flowersec-go/gen"] },
        "typescript": { "status": "complete", "evidence": ["tools/idlgen/main.go", "flowersec-ts/src/gen"] },
        "swift": { "status": "complete", "evidence": ["tools/idlgen/main.go", "flowersec-swift/Sources/Flowersec/Generated", "flowersec-swift/Tests/FlowersecTests/Generated", "flowersec-swift/Tests/FlowersecTests/EndpointTests.swift"] },
        "rust": { "status": "complete", "evidence": ["tools/idlgen/main.go", "flowersec-rust/src/gen", "flowersec-rust/tests/rpc_roundtrip.rs"] }
      }
    },
    {
      "id": "connect",
      "description": "ConnectArtifact, scopes, correlation, and direct/tunnel/automatic connect",
      "implementations": {
        "go": { "status": "complete", "evidence": ["flowersec-go/client", "flowersec-go/protocolio"] },
        "typescript": { "status": "complete", "evidence": ["flowersec-ts/src/connect", "flowersec-ts/src/facade.ts"] },
        "swift": { "status": "complete", "evidence": ["flowersec-swift/Sources/Flowersec/Wire.swift", "flowersec-swift/Sources/Flowersec/RPC.swift"] },
        "rust": { "status": "complete", "evidence": ["flowersec-rust/src/artifact.rs", "flowersec-rust/src/client.rs", "flowersec-rust/tests/direct_integration.rs"] }
      }
    },
    {
      "id": "security",
      "description": "Transport policy, E2EE suites, records, rekey, and secret lifecycle",
      "implementations": {
        "go": { "status": "complete", "evidence": ["flowersec-go/crypto/e2ee", "flowersec-go/transportsecurity"] },
        "typescript": { "status": "complete", "evidence": ["flowersec-ts/src/e2ee", "flowersec-ts/src/client-connect/transportSecurity.ts"] },
        "swift": { "status": "complete", "evidence": ["flowersec-swift/Sources/Flowersec/Handshake.swift", "flowersec-swift/Sources/Flowersec/SecureChannel.swift"] },
        "rust": { "status": "complete", "evidence": ["flowersec-rust/src/e2ee.rs", "flowersec-rust/src/transport_security.rs", "flowersec-rust/tests/e2ee_vectors.rs", "flowersec-rust/tests/handshake_roundtrip.rs"] }
      }
    },
    {
      "id": "session",
      "description": "Yamux, bidirectional streams, StreamHello, framing, limits, and acknowledged liveness",
      "implementations": {
        "go": { "status": "complete", "evidence": ["flowersec-go/mux/yamux", "flowersec-go/streamhello", "flowersec-go/framing/jsonframe"] },
        "typescript": { "status": "complete", "evidence": ["flowersec-ts/src/yamux", "flowersec-ts/src/streamhello", "flowersec-ts/src/framing"] },
        "swift": { "status": "complete", "evidence": ["flowersec-swift/Sources/Flowersec/Yamux.swift", "flowersec-swift/Sources/Flowersec/DataCoding.swift"] },
