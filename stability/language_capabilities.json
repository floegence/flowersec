      "implementations": {
        "go": { "status": "complete", "evidence": ["flowersec-go/endpoint"] },
        "typescript": { "status": "complete", "evidence": ["flowersec-ts/src/endpoint/index.ts", "flowersec-ts/src/endpoint/endpoint.integration.test.ts"] },
        "swift": { "status": "complete", "evidence": ["flowersec-swift/Sources/Flowersec/Endpoint.swift", "flowersec-swift/Sources/Flowersec/ServerHandshake.swift", "flowersec-swift/Tests/FlowersecTests/EndpointTests.swift"] },
