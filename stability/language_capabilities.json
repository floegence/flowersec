        "rust": { "status": "complete", "evidence": ["flowersec-rust/src/controlplane.rs", "idl/flowersec/testdata/v1/token_vectors.json"] }
      }
    },
    {
      "id": "reconnect",
      "description": "One-shot and refreshable artifact sources, backoff, jitter, and termination detection",
      "implementations": {
        "go": { "status": "complete", "evidence": ["flowersec-go/reconnect/reconnect.go", "flowersec-go/reconnect/reconnect_test.go"] },
        "typescript": { "status": "complete", "evidence": ["flowersec-ts/src/reconnect"] },
        "swift": { "status": "complete", "evidence": ["flowersec-swift/Sources/Flowersec/Reconnect.swift", "flowersec-swift/Tests/FlowersecTests/ReconnectTests.swift"] },
        "rust": { "status": "complete", "evidence": ["flowersec-rust/src/reconnect.rs", "flowersec-rust/tests/reconnect_integration.rs"] }
      }
    },
    {
      "id": "proxy",
      "description": "HTTP and WebSocket proxy clients and servers with the stable security policy",
      "implementations": {
        "go": { "status": "complete", "evidence": ["flowersec-go/proxy/client.go", "flowersec-go/proxy/register.go", "flowersec-go/proxy/client_test.go"] },
        "typescript": { "status": "complete", "evidence": ["flowersec-ts/src/proxy/runtime.ts", "flowersec-ts/src/proxy/server.ts", "flowersec-ts/src/proxy/server.integration.test.ts"] },
        "swift": { "status": "complete", "evidence": ["flowersec-swift/Sources/Flowersec/ProxyClient.swift", "flowersec-swift/Sources/Flowersec/ProxyServer.swift", "flowersec-swift/Sources/Flowersec/ProxyNIOWebSocket.swift", "flowersec-swift/Tests/FlowersecTests/ProxyTests.swift"] },
        "rust": { "status": "complete", "evidence": ["flowersec-rust/src/proxy.rs", "flowersec-rust/tests/proxy_integration.rs", "flowersec-rust/examples/interop_harness.rs", "stability/interop_matrix.json"] }
      }
    },
    {
      "id": "observability",
      "description": "Stable error tuple, diagnostics, and observer contracts",
      "implementations": {
        "go": { "status": "complete", "evidence": ["flowersec-go/fserrors", "flowersec-go/observability"] },
        "typescript": { "status": "complete", "evidence": ["flowersec-ts/src/observability", "flowersec-ts/src/utils/errors.ts"] },
        "swift": { "status": "complete", "evidence": ["flowersec-swift/Sources/Flowersec/Wire.swift"] },
        "rust": { "status": "complete", "evidence": ["flowersec-rust/src/error.rs", "flowersec-rust/src/observability.rs", "stability/connect_error_code_registry.json", "stability/connect_diagnostics_code_registry.json"] }
      }
    }
  ],
  "runtime_specific_capabilities": [
    {
      "id": "browser_proxy_runtime",
      "owner": "typescript",
      "reason": "Service Worker and browser page integration require browser JavaScript APIs."
    },
    {
      "id": "deployable_services_and_cli",
      "owner": "go",
      "reason": "Tunnel, proxy gateway, and helper binaries are shared deployables consumed by every SDK."
    },
    {
      "id": "rust_wasm",
      "owner": "rust",
      "reason": "The Rust v0.23 support target is native Linux, macOS, and Windows; browser support remains TypeScript-owned."
    }
  ],
