{
  "version": 1,
  "namespace": "connect",
  "domain": "event",
  "codes": [
    { "code": "connect_ok", "stage": "connect", "result": "ok" },
    { "code": "attach_ok", "stage": "attach", "result": "ok" },
    { "code": "handshake_ok", "stage": "handshake", "result": "ok" },
    { "code": "plaintext_transport", "stage": "transport", "result": "skip" },
    { "code": "scope_ignored_missing_resolver", "stage": "scope", "result": "skip" },
    { "code": "scope_ignored_relaxed_validation", "stage": "scope", "result": "skip" },
    { "code": "ws_close_local", "stage": "close", "result": "skip" },
    { "code": "ws_close_peer_or_error", "stage": "close", "result": "skip" },
    { "code": "ws_error", "stage": "close", "result": "skip" },
    { "code": "diagnostics_overflow", "stage": "reconnect", "result": "skip" },
    { "code": "reconnect_attempt", "stage": "reconnect", "result": "retry" },
    { "code": "reconnect_retry_attempt", "stage": "reconnect", "result": "retry" },
    { "code": "reconnect_scheduled", "stage": "reconnect", "result": "retry" },
    { "code": "reconnect_connected", "stage": "reconnect", "result": "ok" },
    { "code": "reconnect_exhausted", "stage": "reconnect", "result": "fail" },
    { "code": "liveness_timeout", "stage": "yamux", "result": "fail" },
    { "code": "queue_pressure", "stage": "transport", "result": "fail" },
    { "code": "stream_rejected", "stage": "yamux", "result": "fail" },
    { "code": "resource_limit_reached", "stages": ["transport", "yamux", "rpc", "close"], "result": "fail" }
  ],
  "notes": [
    "code_domain=error reuses stability/connect_error_code_registry.json.",
    "elapsed_ms is monotonic milliseconds since the current attempt start; reconnect resets the attempt clock and increments attempt_seq.",
    "resource, current, and limit are optional generic resource fields and must not carry URLs, credentials, stream kinds, RPC type IDs, or application data."
  ]
}
